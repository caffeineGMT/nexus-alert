# CRITICAL: Add your Resend API key here before running campaign
# Sign up at https://resend.com and get your API key from https://resend.com/api-keys
RESEND_API_KEY=

# Email sender configuration
SENDER_NAME=Michael Guo
SENDER_EMAIL=michael@nexus-alert.com

# Hunter.io for email verification (optional - 100 free verifications/month)
# Sign up: https://hunter.io
# API Keys: https://hunter.io/api-keys
HUNTER_API_KEY=

# Apify for Google Maps scraping (optional - for future lead generation)
# Sign up: https://apify.com
# API Keys: https://console.apify.com/account/integrations
APIFY_API_KEY=

# Airtable for lead database/CRM (optional)
# Sign up: https://airtable.com
# API Tokens: https://airtable.com/create/tokens
AIRTABLE_API_KEY=
AIRTABLE_BASE_ID=

# Campaign settings
EMAIL_SEQUENCE_DELAY_DAYS=3
MAX_LEADS_PER_SOURCE=500
SCRAPE_DELAY_MS=2000
