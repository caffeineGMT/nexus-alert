# Email service (for sending cold emails)
RESEND_API_KEY=re_your_key_here

# Hunter.io for email verification (100 free verifications/month)
HUNTER_API_KEY=your_hunter_api_key_here

# SMTP for sending emails (alternative to Resend)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password

# LinkedIn automation (optional - use at your own risk)
LINKEDIN_EMAIL=your_linkedin@email.com
LINKEDIN_PASSWORD=your_password

# Scraping configuration
MAX_LEADS_PER_SOURCE=500
SCRAPE_DELAY_MS=2000

# Campaign settings
EMAIL_SEQUENCE_DELAY_DAYS=3
SENDER_NAME=NEXUS Alert Team
SENDER_EMAIL=hello@nexus-alert.com
