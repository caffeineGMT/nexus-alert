{
  "name": "nexus-alert-backend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "test": "vitest run",
    "test:watch": "vitest",
    "load-test": "node load-test-simple.js",
    "load-test:full": "node load-test.js",
    "load-test:stripe": "./stripe-webhook-load-test.sh",
    "monitor:health": "./scripts/monitor-health.sh",
    "monitor:analytics": "./scripts/analytics-dashboard.js",
    "monitor:all": "./monitoring-dashboard.sh",
    "health": "curl -s https://api.nexus-alert.com/health | jq .",
    "tail": "wrangler tail --env production --format pretty",
    "setup:promo-codes": "node scripts/setup-promo-codes.js",
    "test:drip": "./scripts/test-drip-campaign.sh",
    "analytics:email": "curl -s https://api.nexus-alert.com/api/email-analytics | jq '.summary'"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.5.0",
    "@sentry/cloudflare": "^10.44.0",
    "vitest": "^2.1.0",
    "wrangler": "^3.0.0"
  },
  "dependencies": {
    "resend": "^6.9.4",
    "stripe": "^14.25.0"
  }
}
