# NEXUS Alert Backend Environment Variables
# Copy this file to .env and fill in your actual values

# ─── Cloudflare ─────────────────────────────────────────────────────
# Webhook secret for authenticated API endpoints
WEBHOOK_SECRET=your-random-secret-here

# Environment (production, staging, development)
ENVIRONMENT=development

# ─── Email Service (Resend) ────────────────────────────────────────
# Resend API key for sending transactional emails
RESEND_API_KEY=re_yourAPIkey

# ─── Email Marketing (ConvertKit) ───────────────────────────────────
# ConvertKit API credentials for email automation and sequences
CONVERTKIT_API_KEY=your_convertkit_api_key
CONVERTKIT_API_SECRET=your_convertkit_api_secret

# ConvertKit form ID for landing page signups
CONVERTKIT_FORM_ID=12345678

# ConvertKit tag IDs for segmentation
CONVERTKIT_TAG_FREE=123456
CONVERTKIT_TAG_PREMIUM=123457
CONVERTKIT_TAG_CHURNED=123458
CONVERTKIT_TAG_CONVERTED=123459

# ─── Stripe (Payment Processing) ────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_yourSecretKey
STRIPE_WEBHOOK_SECRET=whsec_yourWebhookSecret
STRIPE_PRICE_ID_PREMIUM=price_yourPriceId

# ─── Error Tracking (Sentry) ────────────────────────────────────────
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# ─── Slack Notifications (Optional) ─────────────────────────────────
# Slack webhook for operational alerts (API failures, etc.)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# ─── Twilio (SMS Notifications - Premium Only) ─────────────────────
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+15551234567
