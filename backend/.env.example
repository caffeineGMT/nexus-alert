# NEXUS Alert Backend - Environment Variables
#
# This file documents all required environment variables for the backend.
# In production, these are set via `wrangler secret put --env production`
# DO NOT put real values in this file or commit secrets to git!

# ═══════════════════════════════════════════════════════════════════════
# STRIPE PAYMENT PROCESSING
# ═══════════════════════════════════════════════════════════════════════

# Stripe secret API key (starts with sk_live_ or sk_test_)
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_XXXXXXXXXXXXXXXXXXXXXX

# Stripe webhook signing secret (starts with whsec_)
# Get from: https://dashboard.stripe.com/webhooks
# After creating webhook endpoint at: https://api.nexus-alert.com/api/webhooks/stripe
STRIPE_WEBHOOK_SECRET=whsec_XXXXXXXXXXXXXXXXXXXXXX

# Stripe price ID for premium tier subscription
# Get from: https://dashboard.stripe.com/products
# Create a product with $4.99/month recurring price
STRIPE_PRICE_ID=price_XXXXXXXXXXXXXXXXXXXXXX

# ═══════════════════════════════════════════════════════════════════════
# EMAIL NOTIFICATIONS (RESEND)
# ═══════════════════════════════════════════════════════════════════════

# Resend API key for sending emails (starts with re_)
# Get from: https://resend.com/api-keys
# Requires verified domain at https://resend.com/domains
RESEND_API_KEY=re_XXXXXXXXXXXXXXXXXXXXXX

# ═══════════════════════════════════════════════════════════════════════
# SMS NOTIFICATIONS (TWILIO) - Premium Tier Only
# ═══════════════════════════════════════════════════════════════════════

# Twilio Account SID (starts with AC)
# Get from: https://console.twilio.com/
TWILIO_ACCOUNT_SID=ACXXXXXXXXXXXXXXXXXXXXXX

# Twilio Auth Token
# Get from: https://console.twilio.com/ (click "View" to reveal)
TWILIO_AUTH_TOKEN=XXXXXXXXXXXXXXXXXXXXXX

# Twilio phone number in E.164 format (e.g., +15551234567)
# Purchase from: https://console.twilio.com/us1/develop/phone-numbers/manage/search
TWILIO_FROM_NUMBER=+15551234567

# ═══════════════════════════════════════════════════════════════════════
# INTERNAL API SECURITY
# ═══════════════════════════════════════════════════════════════════════

# Internal webhook authentication secret
# Generate with: openssl rand -hex 32
# Used for authenticating requests between extension and backend
WEBHOOK_SECRET=XXXXXXXXXXXXXXXXXXXXXX

# ═══════════════════════════════════════════════════════════════════════
# CLOUDFLARE CONFIGURATION (set in wrangler.toml, not via secrets)
# ═══════════════════════════════════════════════════════════════════════

# Environment name (production, staging, development)
# Set in: wrangler.toml [env.production.vars]
ENVIRONMENT=production

# Logging level (debug, info, warn, error)
# Set in: wrangler.toml [env.production.vars]
LOG_LEVEL=info

# ═══════════════════════════════════════════════════════════════════════
# HOW TO SET SECRETS IN PRODUCTION
# ═══════════════════════════════════════════════════════════════════════

# Option 1: Use the helper script (recommended)
# ./scripts/setup-production-secrets.sh

# Option 2: Set manually one by one
# npx wrangler secret put STRIPE_SECRET_KEY --env production
# npx wrangler secret put STRIPE_WEBHOOK_SECRET --env production
# npx wrangler secret put STRIPE_PRICE_ID --env production
# npx wrangler secret put RESEND_API_KEY --env production
# npx wrangler secret put TWILIO_ACCOUNT_SID --env production
# npx wrangler secret put TWILIO_AUTH_TOKEN --env production
# npx wrangler secret put TWILIO_FROM_NUMBER --env production
# npx wrangler secret put WEBHOOK_SECRET --env production

# Verify all secrets are set:
# npx wrangler secret list --env production

# ═══════════════════════════════════════════════════════════════════════
# LOCAL DEVELOPMENT
# ═══════════════════════════════════════════════════════════════════════

# For local development with wrangler dev, create .dev.vars file (gitignored):
# cp .env.example .dev.vars
# Then edit .dev.vars with test/development values

# .dev.vars is automatically loaded by `wrangler dev`
# Do NOT commit .dev.vars to git!

# ═══════════════════════════════════════════════════════════════════════
# EXTERNAL SERVICE SETUP GUIDES
# ═══════════════════════════════════════════════════════════════════════

# Stripe Setup:
# 1. Create product: https://dashboard.stripe.com/products
# 2. Set price to $4.99/month recurring
# 3. Create webhook: https://dashboard.stripe.com/webhooks
#    - URL: https://api.nexus-alert.com/api/webhooks/stripe
#    - Events: checkout.session.completed, customer.subscription.deleted, customer.subscription.updated
# 4. Copy API keys and webhook secret

# Resend Setup:
# 1. Verify domain: https://resend.com/domains
# 2. Add DNS records (SPF, DKIM, DMARC)
# 3. Create API key: https://resend.com/api-keys

# Twilio Setup:
# 1. Sign up: https://www.twilio.com/try-twilio
# 2. Buy phone number: https://console.twilio.com/us1/develop/phone-numbers/manage/search
# 3. Copy Account SID and Auth Token from dashboard
