# Environment Variables for Analytics & Monitoring
# Copy this file to .env.local and fill in your actual values

# ─── Sentry Error Tracking ────────────────────────────────────────────

# Cloudflare Worker (add to wrangler.toml under [env.production.vars])
SENTRY_DSN=https://YOUR_WORKER_DSN@o4506834201010176.ingest.us.sentry.io/PROJECT_ID
ENVIRONMENT=production

# Chrome Extension (update in src/sentry.js)
# DSN is hardcoded in src/sentry.js - update the init() call

# Next.js Web App (add to .env.local in web/ directory)
NEXT_PUBLIC_SENTRY_DSN=https://YOUR_WEB_DSN@o4506834201010176.ingest.us.sentry.io/PROJECT_ID
SENTRY_ORG=nexus-alert
SENTRY_PROJECT=web
SENTRY_AUTH_TOKEN=YOUR_SENTRY_AUTH_TOKEN_HERE

# ─── Analytics (Plausible) ─────────────────────────────────────────────

# No environment variables needed - already configured in layout.tsx
# Dashboard: https://plausible.io/nexus-alert.com

# ─── Uptime Monitoring (BetterUptime) ──────────────────────────────────

# For automated monitor creation (optional)
BETTERUPTIME_API_KEY=your_betteruptime_api_key_here

# ─── Existing Services ──────────────────────────────────────────────────

# Cloudflare Worker
WEBHOOK_SECRET=your_webhook_secret_here
STRIPE_SECRET_KEY=sk_live_xxx
RESEND_API_KEY=re_xxx

# Next.js Web App
NEXT_PUBLIC_CRISP_WEBSITE_ID=your-crisp-website-id-here
NEXT_PUBLIC_FB_PIXEL_ID=your-fb-pixel-id-here
NEXT_PUBLIC_GOOGLE_ADS_ID=your-google-ads-id-here
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=your-verification-code
NEXT_PUBLIC_VERCEL_ENV=production

# ─── How to Get These Values ────────────────────────────────────────────

# Sentry DSN:
# 1. Login to sentry.io
# 2. Create organization "nexus-alert"
# 3. Create projects: worker, extension, web
# 4. Copy DSN from Settings > Client Keys (DSN)
# 5. Create auth token: Settings > Auth Tokens > Create New Token
#    Scopes needed: project:releases, org:read

# Sentry Auth Token (for source map uploads):
# 1. Go to https://sentry.io/settings/account/api/auth-tokens/
# 2. Create new token with scopes: project:releases, org:read
# 3. Copy token to SENTRY_AUTH_TOKEN

# BetterUptime API Key:
# 1. Sign up at https://betteruptime.com
# 2. Go to Team Settings > API Tokens
# 3. Create new API token
# 4. Copy to BETTERUPTIME_API_KEY
# 5. Run: ./scripts/setup-monitoring.sh

# Plausible:
# 1. Already configured! No API key needed for basic usage
# 2. Script tag in layout.tsx handles everything
# 3. View dashboard: https://plausible.io/nexus-alert.com

# ─── Deployment ─────────────────────────────────────────────────────────

# Cloudflare Worker:
# Add to wrangler.toml:
# [env.production.vars]
# SENTRY_DSN = "https://..."
# ENVIRONMENT = "production"

# Next.js (Vercel):
# 1. Go to Vercel Dashboard > Project > Settings > Environment Variables
# 2. Add all NEXT_PUBLIC_* and SENTRY_* variables
# 3. Redeploy

# Chrome Extension:
# 1. Update src/sentry.js with production DSN
# 2. Run: npm run build
# 3. Upload dist/ to Chrome Web Store
