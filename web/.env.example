NEXT_PUBLIC_FB_PIXEL_ID=your-fb-pixel-id-here

# Google Ads Conversion ID
# Format: AW-XXXXXXXXXX
NEXT_PUBLIC_GOOGLE_ADS_ID=your-google-ads-id-here
